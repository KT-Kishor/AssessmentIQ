<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="otpDialog"
        contentWidth="400px" >
        <customHeader>
            <OverflowToolbar
                id="PL_id_ViewDialogHeaderBar"
                class="policyHeaderToolbar"
            >
                <Title
                    id="PL_id_ViewDialogTitle"
                    text="Candidate Verification"
                    level="H4"
                    wrapping="false"
                />
                <ToolbarSpacer />
                <Button
                    id="PL_id_ViewDialogCloseBtn"
                    icon="sap-icon://decline"
                    tooltip="{i18n>closeDialog}"
                    type="Transparent"
                    press="PL_onCloseViewDialog"
                />
            </OverflowToolbar>
        </customHeader>


        <VBox class="sapUiMediumMargin" >

            <Label text="Email"/>

            <Input
                id="emailInput"
                value="{session>/email}"
                liveChange="onEmail"
                editable="false"
                type="Email" valueStateText="{i18n>enterEmail}" />

           <HBox justifyContent="End" width="100%">
   <Button
    id="btnSendOTP"
    text="Send OTP"
    type="Emphasized"
    press=".onSendOTP"
    class="sapUiSmallMarginTop"/>
</HBox>

            <VBox
                id="otpContainer"
                visible="false"
                class="sapUiSmallMarginTop">
                <Label text="Enter OTP"/>

                <Input
                    id="otpInput"
                   liveChange="onOTPchange"
                    type="Number"/>
               <HBox justifyContent="End" width="100%">
                <Button
                    text="Login"
                    type="Accept"
                    press=".onVerifyOTP"
                    class="sapUiSmallMarginTop"/>
                    </HBox>

            </VBox>

        </VBox>

    </Dialog>

</core:FragmentDefinition>
<mvc:View
    controllerName="sap.com.interview.controller.Review"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page Title="Review Answers"
        id="reviewPage"
        showHeader="true"
        class="aiqTestPage">

        <customHeader>
            <Bar class="aiqTimerHeader">
                <contentLeft>
                    <core:HTML content="&lt;div class='aiqHeaderBrand'&gt;&lt;span class='aiqHeaderDot'&gt;&lt;/span&gt; Kalpavriksha AssessIQ&lt;/div&gt;"/>
                </contentLeft>
                <contentMiddle>
                    <Title text="Review Answers" class="aiqReviewMainTitle"/>
                </contentMiddle>
                <contentRight>
                    <Button text="← Back to Results" class="aiqBtnOutline" press="onBackToResults"/>
                </contentRight>
            </Bar>
        </customHeader>

        <ScrollContainer height="100%" horizontal="false" vertical="true" class="aiqTestScrollContainer">
            <VBox class="aiqTestContent">
                
                <!-- <core:HTML id="reviewListHtml" content="&lt;div class='aiqReviewList' id='aiqReviewListContainer'&gt;&lt;/div&gt;"/> -->
                <core:HTML id="reviewListHtml" preferDOM="false"/>
            </VBox>
        </ScrollContainer>

    </Page>
</mvc:View>